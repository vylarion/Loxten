{
  "manifest_version": 3,
  "name": "Loxten",
  "description": "Practical browser security — phishing detection, header auditing, tracker blocking, and link safety analysis.",
  "version": "2.0",
  "action": {
    "default_title": "Loxten",
    "default_popup": "index.html"
  },
  "permissions": [
    "activeTab",
    "webNavigation",
    "storage",
    "webRequest",
    "tabs",
    "scripting",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "*.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}